{
    "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "resources/js/**/*.ts",
            "resources/js/**/*.tsx",
            "resources/js/**/*.js",
            "resources/js/**/*.jsx",
            "resources/js/**/*.vue"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noUnknownAtRules": "off",
                "noConsole": {
                    "options": {
                        "allow": ["warn", "error"]
                    },
                    "level": "error"
                }
            },
            "performance": {
                "noImgElement": "off"
            },
            "correctness": {
                "noUnusedImports": {
                    "level": "error",
                    "fix": "safe"
                },
                "noUnusedVariables": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single"
        }
    }
}
